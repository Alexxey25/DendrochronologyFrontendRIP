{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "HTTP/CORS-fetch: MinIO :9090, Vite :3000, API :8080 (localhost и LAN)",
  "windows": ["main"],
  "permissions": [
    "cors-fetch:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" },
        { "url": "http://192.168.194.69:*" },
        { "url": "http://*:*" }
      ],
      "deny": []
    },
    "core:default",
    "http:allow-fetch",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send"
  ]
}
